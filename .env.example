# App (optional; defaults in config/app.py)
# EMAIL_JANITOR_POLL_INTERVAL=10
# EMAIL_JANITOR_USER_ID=email-janitor-user
# EMAIL_JANITOR_APP_NAME=EmailJanitor

# Email Classifier (optional; defaults in config/classifier.py)
# EMAIL_CLASSIFIER_MODEL=ollama_chat/llama3.1:8b
# EMAIL_CLASSIFIER_CONFIDENCE_THRESHOLD=4.0
# EMAIL_CLASSIFIER_LLM_TIMEOUT_SECONDS=30.0
# EMAIL_CLASSIFIER_LLM_NUM_RETRIES=3

# Gmail integration (optional; defaults in config/gmail.py)
# GMAIL_PROCESSED_LABEL=janitor/done
# GMAIL_URGENT_LABEL=janitor/urgent
# GMAIL_PERSONAL_LABEL=janitor/personal
# GMAIL_NOISE_LABEL=janitor/noise
# GMAIL_PROMOTIONAL_LABEL=janitor/promotions
# GMAIL_INFORMATIONAL_LABEL=janitor/newsletters
# GMAIL_REVIEW_LABEL=janitor/review
# GMAIL_INBOX_QUERY=in:inbox -in:sent

# Gmail auth: place client_secret.json and gmail_token.json in project root.
# Docker: set GOOGLE_APPLICATION_CREDENTIALS=/app/client_secret.json (see compose.yml).

# Database (optional; defaults in config/database.py)
# DATABASE_PATH=email_janitor.db

# Observability (optional)
# LOG_LEVEL=INFO
# OTEL_EXPORT=off                # off | console | otlp
# OTEL_EXPORTER_OTLP_ENDPOINT=   # only used when OTEL_EXPORT=otlp
